generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mongodb"
    url      = env("DATABASE_URL")
}

model User {
    id                        String    @id @default(auto()) @map("_id") @db.ObjectId
    email                     String    @unique
    name                      String
    profilePicture            String?
    userId                    String?
    password                  String?
    loginProvider             String?
    role                      String?
    isVerified                Boolean?   @default(false)
    forgotPasswordToken       String?
    forgotPasswordTokenExpiry DateTime?
    verifyToken               String?
    verifyTokenExpiry         DateTime?
    createdAt                 DateTime  @default(now()) @map("created_at")
    updatedAt                 DateTime  @updatedAt @map("updated_at")
}

model ConsentLog {
    id          String   @id @default(auto()) @map("_id") @db.ObjectId
    consentId   String
    necessary   Boolean
    analytics   Boolean
    marketing   Boolean
    version     Int
    action      String
    userAgent   String?
    ipHash      String?
    country     String?
    region      String?
    city        String?
    pageUrl     String?
    createdAt   DateTime @default(now()) @map("created_at")

    @@index([consentId])
    @@index([createdAt])
}
